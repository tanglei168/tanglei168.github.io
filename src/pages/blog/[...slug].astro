---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props
const { Content, headings } = await post.render()
const tocHeadings = headings.filter(h => h.depth <= 3)
---

<BaseLayout title={post.data.title} description={post.data.description} wide={tocHeadings.length > 0}>
  <div class="animate-fade-in">
    <!-- Two-column layout: TOC sidebar + article -->
    <div class="relative flex gap-10 xl:gap-14">

      <!-- Left TOC sidebar (sticky, only visible on large screens) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block w-52 xl:w-60 shrink-0">
          <nav id="toc" class="sticky top-8 max-h-[calc(100vh-4rem)] overflow-y-auto">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500">目录</p>
            <ul class="space-y-1.5">
              {tocHeadings.map(h => (
                <li style={`padding-left: ${(h.depth - 1) * 12}px`}>
                  <a
                    href={`#${h.slug}`}
                    class="toc-link block text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors leading-snug py-0.5"
                    data-heading={h.slug}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <!-- Article -->
      <article class="min-w-0 flex-1">
        <header class="space-y-4 mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <time>{new Date(post.data.date).toLocaleDateString('zh-CN')}</time>
            {post.data.category && (
              <span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded">
                {post.data.category}
              </span>
            )}
          </div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
            {post.data.title}
          </h1>
          {post.data.description && (
            <p class="text-lg text-gray-600 dark:text-gray-400">
              {post.data.description}
            </p>
          )}
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose prose-gray dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-pre:bg-gray-900">
          <Content />
        </div>

        <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:underline"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            返回博客列表
          </a>
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>

<script>
  ;(function () {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
    if (links.length === 0) return

    const headingEls = Array.from(links).map(a => {
      return document.getElementById(a.dataset.heading || '')
    }).filter(Boolean) as HTMLElement[]

    function setActive(el: HTMLElement | null) {
      links.forEach(a => {
        const on = !!(el && a.dataset.heading === el.id)
        a.classList.toggle('text-blue-600', on)
        a.classList.toggle('dark:text-blue-400', on)
        a.classList.toggle('font-medium', on)
        a.classList.toggle('text-gray-500', !on)
        a.classList.toggle('dark:text-gray-400', !on)
      })
    }

    const obs = new IntersectionObserver(
      entries => {
        const visible = entries.filter(e => e.isIntersecting)
        if (visible.length > 0) {
          const top = visible.reduce((a, b) =>
            a.boundingClientRect.top < b.boundingClientRect.top ? a : b
          )
          setActive(top.target as HTMLElement)
        }
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 }
    )

    headingEls.forEach(h => obs.observe(h))
  })()
</script>
