            <svg class="w-3 h-3 opacity-60" viewBox="0 0 20 20" fill="currentColor"><path d="M5.5 7.5l4.5 4.5 4.5-4.5z"/></svg>
          </summary>
          <div class="absolute z-20 mt-2 left-0 p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl min-w-[280px] max-w-[80vw]">
            <div id="filter-region" class="space-y-3 max-h-72 overflow-y-auto"></div>
          </div>
        </details>

        <button
          class="filter-toggle px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
          data-toggle="family"
          data-zh="家庭"
          data-en="Family"
        >家庭</button>
        <button
          class="filter-toggle px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
