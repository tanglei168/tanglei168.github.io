---
import BaseLayout from '../layouts/BaseLayout.astro'

const SHEET_ID = '1SEbXqBt3D_29WQCUnrF-lzC27GE6UXb2j8YFfMKBQWw'
const SHEET_CSV_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=0`
const SHEET_VIEW_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/edit?usp=sharing`

type Row = {
  id: string
  region: string
  place: string
  transport: string
  route: string
  difficulty: string
  age: string
  elder: boolean
  family: boolean
  season: string
  rating: string
  bestMonth: string
  reason: string
}

const HEADER_MAP: Record<string, keyof Row> = {
  '序号': 'id',
  '地区': 'region',
  '地点': 'place',
  '交通': 'transport',
  '爬山/徒步路线': 'route',
  '难度': 'difficulty',
  '适合年龄': 'age',
  '适合老年人': 'elder',
  '适合家庭出游': 'family',
  '推荐季节': 'season',
  '评价': 'rating',
  '最佳爬山月份': 'bestMonth',
  '推荐理由': 'reason',
}

function parseCSV(text: string): string[][] {
  const rows: string[][] = []
  let field = ''
  let row: string[] = []
  let inQuotes = false
  for (let i = 0; i < text.length; i++) {
    const ch = text[i]
    if (inQuotes) {
      if (ch === '"') {
        if (text[i + 1] === '"') { field += '"'; i++ } else { inQuotes = false }
      } else { field += ch }
    } else {
      if (ch === '"') inQuotes = true
      else if (ch === ',') { row.push(field); field = '' }
      else if (ch === '\n' || ch === '\r') {
        if (ch === '\r' && text[i + 1] === '\n') i++
        row.push(field); rows.push(row); row = []; field = ''
      } else { field += ch }
    }
  }
  if (field.length > 0 || row.length > 0) { row.push(field); rows.push(row) }
  return rows
}

function rowsToData(rows: string[][]): Row[] {
  if (rows.length < 2) return []
  const headers = rows[0].map(h => h.trim())
  const result: Row[] = []
  for (let i = 1; i < rows.length; i++) {
    const raw = rows[i]
    if (!raw || raw.every(v => !v || !v.trim())) continue
    const obj: any = {
      id: '', region: '', place: '', transport: '', route: '',
      difficulty: '', age: '', elder: false, family: false,
      season: '', rating: '', bestMonth: '', reason: '',
    }
    headers.forEach((h, idx) => {
      const key = HEADER_MAP[h]
      if (!key) return
      const v = (raw[idx] || '').trim()
      if (key === 'elder' || key === 'family') {
        obj[key] = v === '是' || v.toLowerCase() === 'yes'
      } else {
        obj[key] = v
      }
    })
    if (!obj.place) continue
    result.push(obj as Row)
  }
  return result
}

let initialRows: Row[] = []
let fetchedAt = ''
try {
  const res = await fetch(SHEET_CSV_URL)
  if (res.ok) {
    const text = await res.text()
    initialRows = rowsToData(parseCSV(text))
    fetchedAt = new Date().toISOString()
  }
} catch (err) {
  console.warn('[sports] build-time fetch failed', err)
}
---

<BaseLayout title="运动">
  <div
    class="space-y-10 animate-fade-in"
    data-sheet-url={SHEET_CSV_URL}
    data-initial-rows={JSON.stringify(initialRows)}
    data-initial-synced={fetchedAt}
  >
    <!-- Header -->
    <header class="space-y-4">
      <h1 class="text-3xl font-bold" data-zh="运动" data-en="Sports">运动</h1>
      <p class="text-gray-600 dark:text-gray-400" data-zh="杭州周边登山徒步路线合集·数据实时同步自 Google Sheet" data-en="A dashboard of hiking trails around Hangzhou · Data syncs live from Google Sheet">
        杭州周边登山徒步路线合集·数据实时同步自 Google Sheet
      </p>
    </header>

    <!-- Loading (shown only if no initial data) -->
    {initialRows.length === 0 && (
      <div id="sports-loading" class="p-12 bg-gray-50 dark:bg-gray-900 rounded-xl text-center">
        <div class="inline-block w-8 h-8 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-4 text-gray-500 dark:text-gray-400" data-zh="正在同步最新数据..." data-en="Syncing latest data...">
          正在同步最新数据...
        </p>
      </div>
    )}

    <!-- Error (only visible when both build-time and client-side fetch fail) -->
    <div id="sports-error" class="hidden p-8 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-center">
      <p class="text-red-700 dark:text-red-300 font-medium" data-zh="数据加载失败，请稍后刷新重试" data-en="Failed to load data. Please refresh to retry.">
        数据加载失败，请稍后刷新重试
      </p>
      <a
        href={SHEET_VIEW_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-3 text-sm text-blue-600 dark:text-blue-400 hover:underline"
        data-zh="直接查看数据源 →"
        data-en="View source sheet →"
      >
        直接查看数据源 →
      </a>
    </div>

    <!-- Content (pre-rendered from build data, refreshed client-side) -->
    <div id="sports-content" class:list={['space-y-10', initialRows.length === 0 && 'hidden']}>
      <!-- Summary Cards -->
      <section class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
        <div class="p-4 sm:p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <div class="text-2xl sm:text-3xl font-bold text-blue-600 dark:text-blue-400" id="stat-total">—</div>
          <div class="mt-1 text-xs sm:text-sm text-gray-500 dark:text-gray-400" data-zh="路线总数" data-en="Total trails">路线总数</div>
        </div>
        <div class="p-4 sm:p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <div class="text-2xl sm:text-3xl font-bold text-purple-600 dark:text-purple-400" id="stat-regions">—</div>
          <div class="mt-1 text-xs sm:text-sm text-gray-500 dark:text-gray-400" data-zh="覆盖地区" data-en="Regions">覆盖地区</div>
        </div>
        <div class="p-4 sm:p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <div class="text-2xl sm:text-3xl font-bold text-green-600 dark:text-green-400" id="stat-family">—</div>
          <div class="mt-1 text-xs sm:text-sm text-gray-500 dark:text-gray-400" data-zh="适合家庭" data-en="Family friendly">适合家庭</div>
        </div>
        <div class="p-4 sm:p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <div class="text-2xl sm:text-3xl font-bold text-orange-600 dark:text-orange-400" id="stat-elder">—</div>
          <div class="mt-1 text-xs sm:text-sm text-gray-500 dark:text-gray-400" data-zh="适合老人" data-en="Elder friendly">适合老人</div>
        </div>
      </section>

      <!-- Charts: Difficulty & Region distribution -->
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <h3 class="text-base font-semibold mb-4" data-zh="难度分布" data-en="Difficulty">难度分布</h3>
          <div class="space-y-3" id="chart-difficulty"></div>
        </div>
        <div class="p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl">
          <h3 class="text-base font-semibold mb-4" data-zh="地区分布 TOP 6" data-en="Top Regions">地区分布 TOP 6</h3>
          <div class="space-y-3" id="chart-region"></div>
        </div>
      </section>

      <!-- Filters -->
      <section class="space-y-4">
        <!-- Search -->
        <div class="relative">
          <input
            type="text"
            id="sports-search"
            class="w-full px-4 py-2 pl-10 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400"
            data-placeholder-zh="搜索地点、路线、推荐理由..."
            data-placeholder-en="Search location, route, reason..."
            placeholder="搜索地点、路线、推荐理由..."
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>

        <!-- Region filter -->
        <div class="space-y-2">
          <div class="text-xs font-medium text-gray-500 dark:text-gray-400" data-zh="地区" data-en="Region">地区</div>
          <div class="flex flex-wrap gap-2" id="filter-region"></div>
        </div>

        <!-- Difficulty filter -->
        <div class="space-y-2">
          <div class="text-xs font-medium text-gray-500 dark:text-gray-400" data-zh="难度" data-en="Difficulty">难度</div>
          <div class="flex flex-wrap gap-2" id="filter-difficulty"></div>
        </div>

        <!-- Boolean toggles -->
        <div class="flex flex-wrap gap-2">
          <button
            class="filter-toggle px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
            data-toggle="family"
            data-zh="仅看家庭友好"
            data-en="Family only"
          >
            仅看家庭友好
          </button>
          <button
            class="filter-toggle px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
            data-toggle="elder"
            data-zh="仅看适合老人"
            data-en="Elder friendly"
          >
            仅看适合老人
          </button>
          <button
            class="filter-toggle px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:border-blue-500 dark:hover:border-blue-400 transition-colors"
            data-toggle="thisMonth"
            data-zh="本月推荐"
            data-en="Best this month"
          >
            本月推荐
          </button>
        </div>
      </section>

      <!-- Results count -->
      <div class="text-sm text-gray-500 dark:text-gray-400 flex items-center justify-between">
        <span>
          <span data-zh="共匹配到" data-en="Matched">共匹配到</span>
          <span class="mx-1 font-semibold text-gray-900 dark:text-gray-100" id="result-count">0</span>
          <span data-zh="条路线" data-en="trails">条路线</span>
        </span>
        <a
          href={SHEET_VIEW_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-blue-600 dark:text-blue-400 hover:underline"
          data-zh="数据源 Google Sheet ↗"
          data-en="Google Sheet source ↗"
        >
          数据源 Google Sheet ↗
        </a>
      </div>

      <!-- Trail cards -->
      <section id="trail-list" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></section>

      <!-- Empty state -->
      <div id="empty-state" class="hidden p-10 bg-gray-50 dark:bg-gray-900 rounded-xl text-center">
        <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-gray-700 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p class="text-gray-500 dark:text-gray-400" data-zh="没有匹配的路线，换个筛选条件试试" data-en="No trails match. Try different filters.">
          没有匹配的路线，换个筛选条件试试
        </p>
      </div>

      <!-- Footer note -->
      <div class="pt-4 text-center text-xs text-gray-500 dark:text-gray-400">
        <span data-zh="最后同步" data-en="Last synced">最后同步</span>
        <span class="ml-1" id="last-synced">—</span>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  type Row = {
    id: string
    region: string
    place: string
    transport: string
    route: string
    difficulty: string
    age: string
    elder: boolean
    family: boolean
    season: string
    rating: string
    bestMonth: string
    reason: string
  }

  const container = document.querySelector('[data-sheet-url]') as HTMLElement
  const sheetUrl = container?.dataset.sheetUrl || ''
  const loadingEl = document.getElementById('sports-loading')
  const errorEl = document.getElementById('sports-error')
  const contentEl = document.getElementById('sports-content')

  const HEADER_MAP: Record<string, keyof Row> = {
    '序号': 'id',
    '地区': 'region',
    '地点': 'place',
    '交通': 'transport',
    '爬山/徒步路线': 'route',
    '难度': 'difficulty',
    '适合年龄': 'age',
    '适合老年人': 'elder' as keyof Row,
    '适合家庭出游': 'family' as keyof Row,
    '推荐季节': 'season',
    '评价': 'rating',
    '最佳爬山月份': 'bestMonth',
    '推荐理由': 'reason',
  }

  function parseCSV(text: string): string[][] {
    const rows: string[][] = []
    let field = ''
    let row: string[] = []
    let inQuotes = false
    for (let i = 0; i < text.length; i++) {
      const ch = text[i]
      if (inQuotes) {
        if (ch === '"') {
          if (text[i + 1] === '"') {
            field += '"'
            i++
          } else {
            inQuotes = false
          }
        } else {
          field += ch
        }
      } else {
        if (ch === '"') {
          inQuotes = true
        } else if (ch === ',') {
          row.push(field)
          field = ''
        } else if (ch === '\n' || ch === '\r') {
          if (ch === '\r' && text[i + 1] === '\n') i++
          row.push(field)
          rows.push(row)
          row = []
          field = ''
        } else {
          field += ch
        }
      }
    }
    if (field.length > 0 || row.length > 0) {
      row.push(field)
      rows.push(row)
    }
    return rows
  }

  function rowsToData(rows: string[][]): Row[] {
    if (rows.length < 2) return []
    const headers = rows[0].map(h => h.trim())
    const result: Row[] = []
    for (let i = 1; i < rows.length; i++) {
      const raw = rows[i]
      if (!raw || raw.every(v => !v || !v.trim())) continue
      const obj: any = {
        id: '', region: '', place: '', transport: '', route: '',
        difficulty: '', age: '', elder: false, family: false,
        season: '', rating: '', bestMonth: '', reason: '',
      }
      headers.forEach((h, idx) => {
        const key = HEADER_MAP[h]
        if (!key) return
        const v = (raw[idx] || '').trim()
        if (key === 'elder' || key === 'family') {
          obj[key] = v === '是' || v.toLowerCase() === 'yes'
        } else {
          obj[key] = v
        }
      })
      if (!obj.place) continue
      result.push(obj as Row)
    }
    return result
  }

  const state = {
    all: [] as Row[],
    region: '全部',
    difficulty: '全部',
    search: '',
    family: false,
    elder: false,
    thisMonth: false,
  }

  const DIFFICULTY_ORDER = ['低', '中', '高']
  const DIFFICULTY_COLORS: Record<string, string> = {
    '低': 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    '中': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400',
    '高': 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
  }
  const DIFFICULTY_BAR: Record<string, string> = {
    '低': 'bg-green-500',
    '中': 'bg-yellow-500',
    '高': 'bg-red-500',
  }
  const REGION_BAR = 'bg-blue-500'

  function countBy(rows: Row[], key: keyof Row): Record<string, number> {
    const counts: Record<string, number> = {}
    for (const r of rows) {
      const v = String(r[key] || '').trim()
      if (!v) continue
      counts[v] = (counts[v] || 0) + 1
    }
    return counts
  }

  function renderStats(rows: Row[]) {
    const setText = (id: string, v: string | number) => {
      const el = document.getElementById(id)
      if (el) el.textContent = String(v)
    }
    setText('stat-total', rows.length)
    const regions = new Set(rows.map(r => r.region).filter(Boolean))
    setText('stat-regions', regions.size)
    setText('stat-family', rows.filter(r => r.family).length)
    setText('stat-elder', rows.filter(r => r.elder).length)
  }

  function renderDifficultyChart(rows: Row[]) {
    const el = document.getElementById('chart-difficulty')
    if (!el) return
    const counts = countBy(rows, 'difficulty')
    const total = rows.length || 1
    el.innerHTML = DIFFICULTY_ORDER
      .filter(k => counts[k])
      .map(k => {
        const n = counts[k]
        const pct = Math.round((n / total) * 100)
        return `
          <div>
            <div class="flex items-center justify-between text-xs mb-1">
              <span class="text-gray-600 dark:text-gray-400">${k}</span>
              <span class="text-gray-500 dark:text-gray-400">${n} · ${pct}%</span>
            </div>
            <div class="h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full ${DIFFICULTY_BAR[k]} rounded-full transition-all duration-500" style="width:${pct}%"></div>
            </div>
          </div>
        `
      }).join('')
  }

  function renderRegionChart(rows: Row[]) {
    const el = document.getElementById('chart-region')
    if (!el) return
    const counts = countBy(rows, 'region')
    const entries = Object.entries(counts).sort((a, b) => b[1] - a[1]).slice(0, 6)
    const max = entries[0]?.[1] || 1
    el.innerHTML = entries.map(([k, n]) => {
      const pct = Math.round((n / max) * 100)
      return `
        <div>
          <div class="flex items-center justify-between text-xs mb-1">
            <span class="text-gray-600 dark:text-gray-400">${k}</span>
            <span class="text-gray-500 dark:text-gray-400">${n}</span>
          </div>
          <div class="h-2 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
            <div class="h-full ${REGION_BAR} rounded-full transition-all duration-500" style="width:${pct}%"></div>
          </div>
        </div>
      `
    }).join('')
  }

  function renderFilterChips() {
    const regions = ['全部', ...Array.from(new Set(state.all.map(r => r.region).filter(Boolean)))]
    const difficulties = ['全部', ...DIFFICULTY_ORDER.filter(d => state.all.some(r => r.difficulty === d))]

    const regionEl = document.getElementById('filter-region')
    const diffEl = document.getElementById('filter-difficulty')

    const makeChip = (value: string, active: boolean, group: 'region' | 'difficulty') => `
      <button
        class="chip px-3 py-1 text-xs rounded-full border transition-colors ${active
          ? 'bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 border-gray-900 dark:border-gray-100'
          : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-400'}"
        data-group="${group}"
        data-value="${value}"
      >${value}</button>
    `

    if (regionEl) regionEl.innerHTML = regions.map(r => makeChip(r, r === state.region, 'region')).join('')
    if (diffEl) diffEl.innerHTML = difficulties.map(d => makeChip(d, d === state.difficulty, 'difficulty')).join('')
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  function currentMonthLabel(): string[] {
    const m = new Date().getMonth() + 1
    return [`${m}月`]
  }

  function applyFilters(): Row[] {
    const q = state.search.trim().toLowerCase()
    const monthLabels = currentMonthLabel()
    return state.all.filter(r => {
      if (state.region !== '全部' && r.region !== state.region) return false
      if (state.difficulty !== '全部' && r.difficulty !== state.difficulty) return false
      if (state.family && !r.family) return false
      if (state.elder && !r.elder) return false
      if (state.thisMonth) {
        const bm = (r.bestMonth || '') + (r.season || '')
        if (!monthLabels.some(m => bm.includes(m))) return false
      }
      if (q) {
        const hay = [r.place, r.region, r.route, r.transport, r.reason, r.season, r.bestMonth].join(' ').toLowerCase()
        if (!hay.includes(q)) return false
      }
      return true
    })
  }

  function renderTrails(rows: Row[]) {
    const listEl = document.getElementById('trail-list')
    const emptyEl = document.getElementById('empty-state')
    const countEl = document.getElementById('result-count')
    if (countEl) countEl.textContent = String(rows.length)
    if (!listEl || !emptyEl) return
    if (rows.length === 0) {
      listEl.innerHTML = ''
      emptyEl.classList.remove('hidden')
      return
    }
    emptyEl.classList.add('hidden')
    listEl.innerHTML = rows.map(r => {
      const diffClass = DIFFICULTY_COLORS[r.difficulty] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
      const familyBadge = r.family
        ? `<span class="inline-flex items-center gap-1 text-xs text-green-700 dark:text-green-400">
             <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
             家庭
           </span>` : ''
      const elderBadge = r.elder
        ? `<span class="inline-flex items-center gap-1 text-xs text-orange-700 dark:text-orange-400">
             <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
             老人
           </span>` : ''
      return `
        <article class="p-5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-blue-500 dark:hover:border-blue-400 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="min-w-0">
              <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-1">
                <span>${escapeHtml(r.region)}</span>
                ${r.age ? `<span>·</span><span>${escapeHtml(r.age)}</span>` : ''}
              </div>
              <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate">${escapeHtml(r.place)}</h3>
            </div>
            <span class="shrink-0 px-2 py-0.5 text-xs rounded-full font-medium ${diffClass}">${escapeHtml(r.difficulty || '—')}</span>
          </div>

          <div class="space-y-1.5 text-xs text-gray-600 dark:text-gray-400">
            ${r.route ? `<div class="flex gap-2"><span class="shrink-0 text-gray-400">路线</span><span class="line-clamp-2">${escapeHtml(r.route)}</span></div>` : ''}
            ${r.transport ? `<div class="flex gap-2"><span class="shrink-0 text-gray-400">交通</span><span class="line-clamp-2">${escapeHtml(r.transport)}</span></div>` : ''}
            ${r.season ? `<div class="flex gap-2"><span class="shrink-0 text-gray-400">季节</span><span>${escapeHtml(r.season)}</span></div>` : ''}
            ${r.bestMonth ? `<div class="flex gap-2"><span class="shrink-0 text-gray-400">最佳</span><span>${escapeHtml(r.bestMonth)}</span></div>` : ''}
          </div>

          ${r.reason ? `<p class="mt-3 text-xs text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-3">${escapeHtml(r.reason)}</p>` : ''}

          ${(familyBadge || elderBadge) ? `<div class="mt-3 flex flex-wrap gap-3">${familyBadge}${elderBadge}</div>` : ''}
        </article>
      `
    }).join('')
  }

  function renderAll() {
    renderStats(state.all)
    renderDifficultyChart(state.all)
    renderRegionChart(state.all)
    renderFilterChips()
    renderTrails(applyFilters())
  }

  function onFilterChange() {
    renderFilterChips()
    renderTrails(applyFilters())
  }

  function bindEvents() {
    document.getElementById('filter-region')?.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('.chip') as HTMLElement | null
      if (!t) return
      state.region = t.dataset.value || '全部'
      onFilterChange()
    })
    document.getElementById('filter-difficulty')?.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('.chip') as HTMLElement | null
      if (!t) return
      state.difficulty = t.dataset.value || '全部'
      onFilterChange()
    })
    document.querySelectorAll('.filter-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = (btn as HTMLElement).dataset.toggle as 'family' | 'elder' | 'thisMonth'
        if (!key) return
        state[key] = !state[key]
        btn.classList.toggle('bg-blue-500')
        btn.classList.toggle('text-white')
        btn.classList.toggle('border-blue-500')
        btn.classList.toggle('bg-white')
        btn.classList.toggle('dark:bg-gray-800')
        btn.classList.toggle('text-gray-600')
        btn.classList.toggle('dark:text-gray-400')
        onFilterChange()
      })
    })
    const search = document.getElementById('sports-search') as HTMLInputElement | null
    search?.addEventListener('input', (e) => {
      state.search = (e.target as HTMLInputElement).value
      renderTrails(applyFilters())
    })
  }

  function updateSynced(d: Date) {
    const el = document.getElementById('last-synced')
    if (el) el.textContent = d.toLocaleString('zh-CN', { hour12: false })
  }

  function hydrate(rows: Row[], syncedAt?: Date) {
    state.all = rows
    loadingEl?.classList.add('hidden')
    contentEl?.classList.remove('hidden')
    renderAll()
    if (syncedAt) updateSynced(syncedAt)
  }

  // 1. Render build-time data immediately (if any)
  let initial: Row[] = []
  try {
    initial = JSON.parse(container?.dataset.initialRows || '[]') as Row[]
  } catch {}
  const initialSynced = container?.dataset.initialSynced
  const hasInitial = initial.length > 0

  if (hasInitial) {
    hydrate(initial, initialSynced ? new Date(initialSynced) : undefined)
    bindEvents()
  }

  // 2. Try to refresh live from Google Sheet
  async function refresh() {
    try {
      const res = await fetch(sheetUrl, { cache: 'no-store' })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const text = await res.text()
      const rows = rowsToData(parseCSV(text))
      if (rows.length === 0) throw new Error('Empty data')

      const wasHydrated = hasInitial
      hydrate(rows, new Date())
      if (!wasHydrated) bindEvents()
    } catch (err) {
      console.warn('Live refresh failed, keeping build-time data:', err)
      if (!hasInitial) {
        loadingEl?.classList.add('hidden')
        errorEl?.classList.remove('hidden')
      }
    }
  }

  refresh()
</script>
