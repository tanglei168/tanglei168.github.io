            <span id="difficulty-badge" class="hidden text-[10px] px-1.5 py-0.5 bg-blue-500 text-white rounded-full leading-none"></span>
            <svg class="w-3 h-3 opacity-60" viewBox="0 0 20 20" fill="currentColor"><path d="M5.5 7.5l4.5 4.5 4.5-4.5z"/></svg>
          </summary>
          <div class="absolute z-20 mt-2 left-0 p-3 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-xl min-w-[180px]">
            <div id="filter-difficulty" class="flex flex-wrap gap-2"></div>
          </div>
        </details>

        <details class="filter-dropdown relative">
          <summary class="list-none cursor-pointer flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:border-blue-500 dark:hover:border-blue-400 transition-colors marker:hidden [&::-webkit-details-marker]:hidden">
