          <span class="font-semibold text-gray-900 dark:text-gray-100" id="result-count">0</span>
          <span data-zh="条" data-en="trails">条</span>
        </span>
        <button
          id="clear-filters"
          class="hidden px-2.5 py-1 text-xs text-blue-600 dark:text-blue-400 hover:underline"
          data-zh="清除"
          data-en="Clear"
        >清除</button>
      </section>

      <!-- Trail cards (priority lifted, denser grid) -->
      <section id="trail-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3"></section>

      <!-- Empty state -->
      <div id="empty-state" class="hidden p-8 bg-gray-50 dark:bg-gray-900 rounded-xl text-center">
        <p id="empty-text" class="text-sm text-gray-500 dark:text-gray-400" data-zh="没有匹配的路线，换个筛选条件试试" data-en="No items match. Try different filters.">
          没有匹配的路线，换个筛选条件试试
        </p>
        <a
          id="empty-cta"
          href={SHEET_VIEW_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden inline-block mt-3 text-sm text-blue-600 dark:text-blue-400 hover:underline"
          data-zh="到 Google Sheet 添加 →"
          data-en="Add via Google Sheet →"
        >到 Google Sheet 添加 →</a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  type Category = '爬山' | '露营' | '公园'
  const CATEGORIES: Category[] = ['爬山', '露营', '公园']

  type Row = {
    id: string
    type: Category
    region: string
    place: string
    transport: string
    route: string
    difficulty: string
    age: string
    elder: boolean
    family: boolean
    season: string
    rating: string
    bestMonth: string
    reason: string
  }

  function normalizeCategory(s: string): Category {
    const v = (s || '').trim()
    if (v.includes('露营')) return '露营'
    if (v.includes('公园')) return '公园'
    return '爬山'
  }

  const container = document.querySelector('[data-sheet-url]') as HTMLElement
  const sheetUrl = container?.dataset.sheetUrl || ''
  const loadingEl = document.getElementById('sports-loading')
  const errorEl = document.getElementById('sports-error')
  const contentEl = document.getElementById('sports-content')

  const HEADER_MAP: Record<string, keyof Row> = {
    '序号': 'id',
    '类型': 'type',
    '分类': 'type',
    '地区': 'region',
    '地点': 'place',
    '交通': 'transport',
    '爬山/徒步路线': 'route',
    '路线/特色': 'route',
    '路线': 'route',
    '特色': 'route',
    '难度': 'difficulty',
    '适合年龄': 'age',
    '适合老年人': 'elder' as keyof Row,
    '适合家庭出游': 'family' as keyof Row,
    '推荐季节': 'season',
    '评价': 'rating',
    '最佳爬山月份': 'bestMonth',
    '最佳月份': 'bestMonth',
    '推荐月份': 'bestMonth',
    '推荐理由': 'reason',
  }

  function parseCSV(text: string): string[][] {
    const rows: string[][] = []
    let field = ''
    let row: string[] = []
    let inQuotes = false
    for (let i = 0; i < text.length; i++) {
      const ch = text[i]
      if (inQuotes) {
        if (ch === '"') {
          if (text[i + 1] === '"') {
            field += '"'
            i++
          } else {
            inQuotes = false
          }
        } else {
          field += ch
        }
      } else {
        if (ch === '"') {
          inQuotes = true
        } else if (ch === ',') {
          row.push(field)
          field = ''
        } else if (ch === '\n' || ch === '\r') {
          if (ch === '\r' && text[i + 1] === '\n') i++
          row.push(field)
          rows.push(row)
          row = []
          field = ''
        } else {
          field += ch
        }
      }
    }
    if (field.length > 0 || row.length > 0) {
      row.push(field)
      rows.push(row)
    }
    return rows
  }

  function rowsToData(rows: string[][]): Row[] {
    if (rows.length < 2) return []
    const headers = rows[0].map(h => h.trim())
    const result: Row[] = []
    for (let i = 1; i < rows.length; i++) {
      const raw = rows[i]
      if (!raw || raw.every(v => !v || !v.trim())) continue
      const obj: any = {
        id: '', type: '爬山' as Category,
        region: '', place: '', transport: '', route: '',
        difficulty: '', age: '', elder: false, family: false,
        season: '', rating: '', bestMonth: '', reason: '',
      }
      headers.forEach((h, idx) => {
        const key = HEADER_MAP[h]
        if (!key) return
        const v = (raw[idx] || '').trim()
        if (key === 'elder' || key === 'family') {
          obj[key] = v === '是' || v.toLowerCase() === 'yes'
        } else if (key === 'type') {
          obj.type = normalizeCategory(v)
        } else {
          obj[key] = v
        }
      })
      if (!obj.place) continue
      result.push(obj as Row)
    }
    return result
  }

  type Decade = '上' | '中' | '下'
  const ALL_DECADES: Decade[] = ['上', '中', '下']

  const state = {
    all: [] as Row[],
    tab: '爬山' as Category,
    regions: new Set<string>(),
    difficulties: new Set<string>(),
    monthDecades: new Set<string>(),
    search: '',
    family: false,
    elder: false,
  }

  function tabRows(): Row[] {
    return state.all.filter(r => r.type === state.tab)
  }

  const DIFFICULTY_ORDER = ['低', '中', '高']
  const DIFFICULTY_COLORS: Record<string, string> = {
    '低': 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    '中': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400',
    '高': 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
  }
  // 露营 Tab 重定义此列含义：是否支持野炊
  const COOKING_ORDER = ['是', '否']
  const COOKING_COLORS: Record<string, string> = {
    '是': 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    '否': 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
  }
  const COOKING_DISPLAY: Record<string, { zh: string; en: string }> = {
    '是': { zh: '可野炊', en: 'BBQ ✓' },
    '否': { zh: '禁炊', en: 'BBQ ✗' },
  }
  function isCampingTab(): boolean { return state.tab === '露营' }
  function difficultyOrder(): string[] { return isCampingTab() ? COOKING_ORDER : DIFFICULTY_ORDER }
  function difficultyColor(v: string): string {
    const map = isCampingTab() ? COOKING_COLORS : DIFFICULTY_COLORS
    return map[v] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
  }
  function difficultyDisplay(v: string): string {
    if (!v) return '—'
    if (isCampingTab()) return COOKING_DISPLAY[v]?.zh || v
    return v
  }

  function decadeKey(m: number, d: Decade): string {
    return `${m}-${d}`
  }

  function parseDecadeWord(s: string): Decade | null {
    if (s === '初' || s === '上' || s === '上旬') return '上'
    if (s === '中' || s === '中旬') return '中'
    if (s === '底' || s === '末' || s === '下' || s === '下旬') return '下'
    return null
  }

  function expandRange(a: number, aD: Decade | null, b: number, bD: Decade | null): string[] {
    const result: string[] = []
    let months: number[] = []
    if (a <= b) {
      for (let i = a; i <= b; i++) months.push(i)
    } else {
      for (let i = a; i <= 12; i++) months.push(i)
      for (let i = 1; i <= b; i++) months.push(i)
    }
    months.forEach((m, idx) => {
      const isFirst = idx === 0
      const isLast = idx === months.length - 1
      const startD: Decade = (isFirst && aD) ? aD : '上'
      const endD: Decade = (isLast && bD) ? bD : '下'
      const startIdx = ALL_DECADES.indexOf(startD)
      const endIdx = ALL_DECADES.indexOf(endD)
      const lo = Math.min(startIdx, endIdx)
      const hi = Math.max(startIdx, endIdx)
      for (let i = lo; i <= hi; i++) result.push(decadeKey(m, ALL_DECADES[i]))
    })
    return result
  }

  function parseMonthDecades(text: string): Set<string> {
    const set = new Set<string>()
    if (!text) return set
    const normalized = text.replace(/[–—~～]/g, '-')
    const parts = normalized.split(/[、，,]/)
    for (const p of parts) {
      const t = p.trim()
      if (!t) continue
      const range = t.match(/^(\d{1,2})\s*月\s*(初|上旬|上|中旬|中|底|末|下旬|下)?\s*-\s*(\d{1,2})\s*月\s*(初|上旬|上|中旬|中|底|末|下旬|下)?$/)
      if (range) {
        const a = parseInt(range[1], 10)
        const aD = parseDecadeWord(range[2] || '')
        const b = parseInt(range[3], 10)
        const bD = parseDecadeWord(range[4] || '')
        if (a >= 1 && a <= 12 && b >= 1 && b <= 12) {
          for (const k of expandRange(a, aD, b, bD)) set.add(k)
        }
        continue
      }
      const single = t.match(/^(\d{1,2})\s*月\s*(初|上旬|上|中旬|中|底|末|下旬|下)?$/)
      if (single) {
        const m = parseInt(single[1], 10)
        const d = parseDecadeWord(single[2] || '')
        if (m >= 1 && m <= 12) {
          if (d) set.add(decadeKey(m, d))
          else for (const dd of ALL_DECADES) set.add(decadeKey(m, dd))
        }
      }
    }
    return set
  }

  // Mine 旬-precision hints from free-form reason text.
  // Recognizes "3月底"、"4月初"、"10月中旬"、"11月上中旬"、"9月下旬至10月初" 等。
  const REASON_DECADE_RE = /(\d{1,2})\s*月\s*(上中下旬|上中旬|中下旬|上下旬|上旬|中旬|下旬|底|末|初|上|中|下)/g
  function decadesFromMarker(marker: string): Decade[] {
    if (marker === '上中下旬') return ['上', '中', '下']
    if (marker === '上中旬') return ['上', '中']
    if (marker === '中下旬') return ['中', '下']
    if (marker === '上下旬') return ['上', '下']
    if (marker === '初' || marker === '上' || marker === '上旬') return ['上']
    if (marker === '中' || marker === '中旬') return ['中']
    if (marker === '底' || marker === '末' || marker === '下' || marker === '下旬') return ['下']
    return []
  }

  function extractDecadesFromReason(reason: string): Set<string> {
    const set = new Set<string>()
    if (!reason) return set
    let m: RegExpExecArray | null
    REASON_DECADE_RE.lastIndex = 0
    while ((m = REASON_DECADE_RE.exec(reason)) !== null) {
      const month = parseInt(m[1], 10)
      if (month < 1 || month > 12) continue
      for (const d of decadesFromMarker(m[2])) {
        set.add(decadeKey(month, d))
      }
    }
    return set
  }

  // For a row: prefer 旬-precise hints from reason for any month it covers,
  // and fall back to bestMonth's all-旬 expansion for months reason doesn't refine.
  function rowDecades(r: Row): Set<string> {
    const base = parseMonthDecades(r.bestMonth)
    const refined = extractDecadesFromReason(r.reason)
    if (refined.size === 0) return base
    const refinedMonths = new Set<number>()
    refined.forEach(k => refinedMonths.add(parseInt(k.split('-')[0], 10)))
    const out = new Set<string>()
    base.forEach(k => {
      const mm = parseInt(k.split('-')[0], 10)
      if (!refinedMonths.has(mm)) out.add(k)
    })
    refined.forEach(k => out.add(k))
    return out
  }

  function currentDecade(): Decade {
    const day = new Date().getDate()
    return day <= 10 ? '上' : day <= 20 ? '中' : '下'
  }

  function countBy(rows: Row[], key: keyof Row): Record<string, number> {
    const counts: Record<string, number> = {}
    for (const r of rows) {
      const v = String(r[key] || '').trim()
      if (!v) continue
      counts[v] = (counts[v] || 0) + 1
    }
    return counts
  }

  function renderStats(rows: Row[]) {
    const setText = (id: string, v: string | number) => {
      const el = document.getElementById(id)
      if (el) el.textContent = String(v)
    }
    setText('stat-total', rows.length)
    const regions = new Set(rows.map(r => r.region).filter(Boolean))
    setText('stat-regions', regions.size)
    setText('stat-family', rows.filter(r => r.family).length)
    setText('stat-elder', rows.filter(r => r.elder).length)
  }

  function renderTabCounts() {
    for (const c of CATEGORIES) {
      const el = document.querySelector(`[data-tab-count="${c}"]`)
      if (el) el.textContent = String(state.all.filter(r => r.type === c).length)
    }
  }

  function renderBadge(id: string, count: number) {
    const badge = document.getElementById(id)
    if (!badge) return
    if (count > 0) {
      badge.textContent = String(count)
      badge.classList.remove('hidden')
    } else {
      badge.classList.add('hidden')
    }
  }

  function renderDifficultyFilter() {
    const el = document.getElementById('filter-difficulty')
    if (!el) return
    const counts = countBy(tabRows(), 'difficulty')
    const order = difficultyOrder()
    el.innerHTML = order.filter(k => counts[k]).map(k => {
      const n = counts[k]
      const active = state.difficulties.has(k)
      const label = isCampingTab() ? (COOKING_DISPLAY[k]?.zh || k) : k
      return `
        <button
          type="button"
          class="chip px-3 py-1 text-xs rounded-full border transition-colors ${active
            ? 'bg-blue-500 text-white border-blue-500'
            : 'bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:border-blue-500 dark:hover:border-blue-400'}"
          data-value="${k}"
        >${escapeHtml(label)} <span class="opacity-70">${n}</span></button>
      `
    }).join('')
    renderBadge('difficulty-badge', state.difficulties.size)
  }

  function renderDifficultyLabel() {
    const el = document.getElementById('difficulty-label')
    if (!el) return
    if (isCampingTab()) {
      el.textContent = '是否支持野炊'
      el.setAttribute('data-zh', '是否支持野炊')
      el.setAttribute('data-en', 'BBQ allowed')
    } else {
      el.textContent = '难度'
      el.setAttribute('data-zh', '难度')
      el.setAttribute('data-en', 'Difficulty')
    }
  }

  const HANGZHOU_DISTRICTS = new Set([
    '西湖区', '上城区', '下城区', '江干区', '拱墅区', '滨江区',
    '萧山区', '余杭区', '临平区', '钱塘区', '富阳区', '临安区',
    '桐庐县', '淳安县', '建德市',
  ])
  const CITY_ORDER = ['杭州', '绍兴', '湖州', '宁波', '嘉兴', '台州', '金华', '舟山']

  function regionCity(region: string): string {
    if (region.includes('·')) return region.split('·')[0]
    if (HANGZHOU_DISTRICTS.has(region)) return '杭州'
    return region
  }

  function renderRegionFilter() {
    const el = document.getElementById('filter-region')
    if (!el) return
    const counts = countBy(tabRows(), 'region')
    const groups: Record<string, { region: string; n: number }[]> = {}
    Object.entries(counts).forEach(([region, n]) => {
      const city = regionCity(region)
      if (!groups[city]) groups[city] = []
      groups[city].push({ region, n })
    })
    const ordered = Object.entries(groups)
      .map(([city, arr]) => ({ city, arr, total: arr.reduce((s, x) => s + x.n, 0) }))
      .sort((a, b) => {
        const ai = CITY_ORDER.indexOf(a.city)
        const bi = CITY_ORDER.indexOf(b.city)
        if (ai !== -1 || bi !== -1) {
          if (ai === -1) return 1
          if (bi === -1) return -1
          return ai - bi
        }
        return b.total - a.total
      })

    el.innerHTML = ordered.map(({ city, arr, total }) => {
      arr.sort((a, b) => b.n - a.n)
      const chips = arr.map(({ region, n }) => {
        const active = state.regions.has(region)
        const display = region === city ? region : (region.includes('·') ? region.split('·').slice(1).join('·') : region)
        return `<button
          type="button"
          class="chip px-2.5 py-1 text-xs rounded-full border transition-colors ${active
            ? 'bg-blue-500 text-white border-blue-500'
            : 'bg-gray-50 dark:bg-gray-700/50 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-600 hover:border-blue-500 dark:hover:border-blue-400'}"
          data-value="${escapeHtml(region)}"
        >${escapeHtml(display)} <span class="opacity-70">${n}</span></button>`
      }).join('')
      return `
        <div>
          <div class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 mb-1.5 flex items-baseline gap-1.5">
            <span>${escapeHtml(city)}</span>
            <span class="text-gray-400 dark:text-gray-500 font-normal">${total}</span>
          </div>
          <div class="flex flex-wrap gap-1.5">${chips}</div>
        </div>
      `
    }).join('')
    renderBadge('region-badge', state.regions.size)
  }

  function renderMonthChart() {
    const el = document.getElementById('chart-month')
    if (!el) return
    const counts: number[][] = Array.from({ length: 12 }, () => [0, 0, 0])
    for (const r of tabRows()) {
      const decades = rowDecades(r)
      decades.forEach(k => {
        const [mStr, d] = k.split('-')
        const m = parseInt(mStr, 10)
        const di = ALL_DECADES.indexOf(d as Decade)
        if (m >= 1 && m <= 12 && di >= 0) counts[m - 1][di]++
      })
    }
    let max = 0
    for (const row of counts) for (const n of row) if (n > max) max = n
    if (max < 1) max = 1

    const today = new Date()
    const curMonth = today.getMonth() + 1
    const curDec = currentDecade()

    let html = ''
    for (let di = 0; di < 3; di++) {
      const decade = ALL_DECADES[di]
      const isCurrentRow = decade === curDec
      const rowLabelCls = isCurrentRow
        ? 'text-gray-700 dark:text-gray-200 font-semibold'
        : 'text-gray-500 dark:text-gray-400'
      html += `
        <button
          type="button"
          class="month-row-label text-[11px] sm:text-xs ${rowLabelCls} hover:text-blue-600 dark:hover:text-blue-400 cursor-pointer text-right pr-1.5 self-center tracking-wide"
          data-decade="${decade}"
          title="切换 ${decade}旬 整行"
        >${decade}旬</button>
      `
      for (let mi = 0; mi < 12; mi++) {
        const m = mi + 1
        const n = counts[mi][di]
        const key = decadeKey(m, decade)
        const active = state.monthDecades.has(key)
        const isCurrent = m === curMonth && decade === curDec
        const intensity = max > 0 ? n / max : 0
        const bg = n === 0
          ? ''
          : `background-color: rgba(59, 130, 246, ${0.16 + intensity * 0.76});`
        const textCls = active
          ? 'text-white font-semibold'
          : intensity >= 0.55 ? 'text-white' : intensity >= 0.28 ? 'text-gray-800 dark:text-gray-100' : 'text-gray-600 dark:text-gray-300'
        const ringCls = active
          ? 'ring-2 ring-blue-500 dark:ring-blue-400 shadow-sm shadow-blue-500/20'
          : n === 0
            ? 'bg-gray-50 dark:bg-gray-700/30 hover:ring-1 hover:ring-blue-300 dark:hover:ring-blue-700'
            : 'hover:ring-1 hover:ring-blue-400 hover:scale-[1.04]'
        const outlineCls = isCurrent ? 'ring-2 ring-orange-400 ring-offset-2 ring-offset-white dark:ring-offset-gray-800' : ''
        html += `
          <button
            type="button"
            class="month-cell aspect-square min-w-0 rounded-md flex items-center justify-center text-[11px] sm:text-xs transition-all duration-150 relative ${ringCls} ${outlineCls}"
            style="${active ? '' : bg}"
            data-month="${m}"
            data-decade="${decade}"
            aria-label="${m}月${decade}旬 ${n}条"
            aria-pressed="${active}"
            title="${m}月${decade}旬 · ${n} 条路线"
          ><span class="${textCls}">${n || ''}</span></button>
        `
      }
    }
    // Bottom row: empty corner + month labels 1-12
    html += `<span></span>`
    for (let m = 1; m <= 12; m++) {
      const isCurrent = m === curMonth
      const labelCls = isCurrent
        ? 'text-orange-600 dark:text-orange-400 font-bold'
        : 'text-gray-500 dark:text-gray-400'
      html += `
        <button
          type="button"
          class="month-col-label text-[11px] sm:text-xs ${labelCls} hover:text-blue-600 dark:hover:text-blue-400 cursor-pointer pt-1 text-center"
          data-month="${m}"
          title="切换 ${m}月 整列"
        >${m}</button>
      `
    }
    el.innerHTML = html
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  function applyFilters(): Row[] {
    const q = state.search.trim().toLowerCase()
    return tabRows().filter(r => {
      if (state.regions.size > 0 && !state.regions.has(r.region)) return false
      if (state.difficulties.size > 0 && !state.difficulties.has(r.difficulty)) return false
      if (state.monthDecades.size > 0) {
        const decades = rowDecades(r)
        let hit = false
        for (const k of state.monthDecades) {
          if (decades.has(k)) { hit = true; break }
        }
        if (!hit) return false
      }
      if (state.family && !r.family) return false
      if (state.elder && !r.elder) return false
      if (q) {
        const hay = [r.place, r.region, r.route, r.transport, r.reason, r.season, r.bestMonth].join(' ').toLowerCase()
        if (!hay.includes(q)) return false
      }
      return true
    })
  }

  function renderTrails(rows: Row[]) {
    const listEl = document.getElementById('trail-list')
    const emptyEl = document.getElementById('empty-state')
    const emptyTextEl = document.getElementById('empty-text')
    const emptyCtaEl = document.getElementById('empty-cta')
    const countEl = document.getElementById('result-count')
    if (countEl) countEl.textContent = String(rows.length)
    if (!listEl || !emptyEl) return
    if (rows.length === 0) {
      listEl.innerHTML = ''
      emptyEl.classList.remove('hidden')
      const noDataInTab = tabRows().length === 0
      if (emptyTextEl) {
        if (noDataInTab) {
          emptyTextEl.textContent = `「${state.tab}」分类暂无数据，去 Google Sheet 录入第一条`
          emptyTextEl.setAttribute('data-zh', `「${state.tab}」分类暂无数据，去 Google Sheet 录入第一条`)
          emptyTextEl.setAttribute('data-en', `No ${state.tab} entries yet — add the first one in the source sheet`)
        } else {
          emptyTextEl.textContent = '没有匹配的路线，换个筛选条件试试'
          emptyTextEl.setAttribute('data-zh', '没有匹配的路线，换个筛选条件试试')
          emptyTextEl.setAttribute('data-en', 'No items match. Try different filters.')
        }
      }
      emptyCtaEl?.classList.toggle('hidden', !noDataInTab)
      return
    }
    emptyEl.classList.add('hidden')
    listEl.innerHTML = rows.map(r => {
      const diffClass = difficultyColor(r.difficulty)
      const diffText = difficultyDisplay(r.difficulty)
      const familyBadge = r.family
        ? `<span class="inline-flex items-center gap-1 text-xs text-green-700 dark:text-green-400">
             <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
             家庭
           </span>` : ''
      const elderBadge = r.elder
        ? `<span class="inline-flex items-center gap-1 text-xs text-orange-700 dark:text-orange-400">
             <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
             老人
           </span>` : ''
      return `
        <article class="p-3.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl hover:border-blue-500 dark:hover:border-blue-400 hover:shadow-md hover:shadow-blue-500/10 transition-all duration-300">
          <div class="flex items-start justify-between gap-2 mb-1.5">
            <div class="min-w-0">
              <div class="flex items-center gap-2 text-[11px] text-gray-500 dark:text-gray-400 mb-0.5">
                <span>${escapeHtml(r.region)}</span>
                ${r.age ? `<span>·</span><span>${escapeHtml(r.age)}</span>` : ''}
              </div>
              <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">${escapeHtml(r.place)}</h3>
            </div>
            <span class="shrink-0 px-2 py-0.5 text-[11px] rounded-full font-medium ${diffClass}">${escapeHtml(diffText)}</span>
          </div>

          <div class="space-y-1 text-[11px] text-gray-600 dark:text-gray-400">
            ${r.route ? `<div class="flex gap-1.5"><span class="shrink-0 text-gray-400">路线</span><span class="line-clamp-2">${escapeHtml(r.route)}</span></div>` : ''}
            ${r.bestMonth ? `<div class="flex gap-1.5"><span class="shrink-0 text-gray-400">最佳</span><span class="line-clamp-1">${escapeHtml(r.bestMonth)}</span></div>` : ''}
            ${r.transport ? `<div class="flex gap-1.5"><span class="shrink-0 text-gray-400">交通</span><span class="line-clamp-1">${escapeHtml(r.transport)}</span></div>` : ''}
          </div>

          ${r.reason ? `<p class="mt-2 text-[11px] text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-2">${escapeHtml(r.reason)}</p>` : ''}

          ${(familyBadge || elderBadge) ? `<div class="mt-2 flex flex-wrap gap-2">${familyBadge}${elderBadge}</div>` : ''}
        </article>
      `
    }).join('')
  }

  function hasActiveFilter(): boolean {
    return state.regions.size > 0
      || state.difficulties.size > 0
      || state.monthDecades.size > 0
      || state.family
      || state.elder
      || state.search.trim().length > 0
  }

  function renderClearButton() {
    const btn = document.getElementById('clear-filters')
    if (!btn) return
    btn.classList.toggle('hidden', !hasActiveFilter())
  }

  function renderAll() {
    renderTabCounts()
    renderStats(tabRows())
    renderDifficultyLabel()
    renderMonthChart()
    renderDifficultyFilter()
    renderRegionFilter()
    renderTrails(applyFilters())
    renderClearButton()
  }

  function onFilterChange() {
    renderMonthChart()
    renderDifficultyFilter()
    renderRegionFilter()
    renderTrails(applyFilters())
    renderClearButton()
  }

  function toggleInSet<T>(set: Set<T>, value: T) {
    if (set.has(value)) set.delete(value)
    else set.add(value)
  }

  function setToggleVisuals(btn: Element, on: boolean) {
    btn.classList.toggle('bg-blue-500', on)
    btn.classList.toggle('text-white', on)
    btn.classList.toggle('border-blue-500', on)
    btn.classList.toggle('bg-white', !on)
    btn.classList.toggle('dark:bg-gray-800', !on)
    btn.classList.toggle('text-gray-600', !on)
    btn.classList.toggle('dark:text-gray-400', !on)
  }

  function toggleMonthCell(m: number, d: Decade) {
    const key = decadeKey(m, d)
    if (state.monthDecades.has(key)) state.monthDecades.delete(key)
    else state.monthDecades.add(key)
  }

  function toggleMonthRow(d: Decade) {
    const allOn = Array.from({ length: 12 }, (_, i) => state.monthDecades.has(decadeKey(i + 1, d))).every(Boolean)
    for (let m = 1; m <= 12; m++) {
      const k = decadeKey(m, d)
      if (allOn) state.monthDecades.delete(k)
      else state.monthDecades.add(k)
    }
  }

  function toggleMonthCol(m: number) {
    const allOn = ALL_DECADES.every(d => state.monthDecades.has(decadeKey(m, d)))
    for (const d of ALL_DECADES) {
      const k = decadeKey(m, d)
      if (allOn) state.monthDecades.delete(k)
      else state.monthDecades.add(k)
    }
  }

  function setTabVisuals() {
    document.querySelectorAll('.sports-tab').forEach(btn => {
      const tab = (btn as HTMLElement).dataset.tab as Category
      const active = tab === state.tab
      btn.classList.toggle('bg-white', active)
      btn.classList.toggle('dark:bg-gray-700', active)
      btn.classList.toggle('text-gray-900', active)
      btn.classList.toggle('dark:text-white', active)
      btn.classList.toggle('shadow-sm', active)
      btn.classList.toggle('text-gray-500', !active)
      btn.classList.toggle('dark:text-gray-400', !active)
      btn.classList.toggle('hover:text-gray-700', !active)
      btn.classList.toggle('dark:hover:text-gray-200', !active)
    })
  }

  function resetFilters() {
    state.regions.clear()
    state.difficulties.clear()
    state.monthDecades.clear()
    state.search = ''
    state.family = false
    state.elder = false
    const search = document.getElementById('sports-search') as HTMLInputElement | null
    if (search) search.value = ''
    document.querySelectorAll('.filter-toggle').forEach(btn => {
      setToggleVisuals(btn, false)
    })
  }

  function switchTab(t: Category) {
    if (state.tab === t) return
    state.tab = t
    resetFilters()
    // Re-apply default current-decade selection only if there is data in the new tab
    if (tabRows().length > 0) {
      const m = new Date().getMonth() + 1
      state.monthDecades.add(decadeKey(m, currentDecade()))
    }
    setTabVisuals()
    renderAll()
  }

  function bindEvents() {
    document.querySelectorAll('.sports-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = (btn as HTMLElement).dataset.tab as Category
        if (t) switchTab(t)
      })
    })
    document.getElementById('chart-month')?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      const cell = target.closest('.month-cell') as HTMLElement | null
      if (cell) {
        const m = parseInt(cell.dataset.month || '0', 10)
        const d = (cell.dataset.decade || '') as Decade
        if (m && d) { toggleMonthCell(m, d); onFilterChange() }
        return
      }
      const rowLabel = target.closest('.month-row-label') as HTMLElement | null
      if (rowLabel) {
        const d = (rowLabel.dataset.decade || '') as Decade
        if (d) { toggleMonthRow(d); onFilterChange() }
        return
      }
      const colLabel = target.closest('.month-col-label') as HTMLElement | null
      if (colLabel) {
        const m = parseInt(colLabel.dataset.month || '0', 10)
        if (m) { toggleMonthCol(m); onFilterChange() }
      }
    })
    document.getElementById('filter-difficulty')?.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('.chip') as HTMLElement | null
      if (!t) return
      const v = t.dataset.value || ''
      if (!v) return
      toggleInSet(state.difficulties, v)
      onFilterChange()
    })
    document.getElementById('filter-region')?.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('.chip') as HTMLElement | null
      if (!t) return
      const v = t.dataset.value || ''
      if (!v) return
      toggleInSet(state.regions, v)
      onFilterChange()
    })
    document.querySelectorAll('.filter-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = (btn as HTMLElement).dataset.toggle as 'family' | 'elder'
        if (!key) return
        state[key] = !state[key]
        setToggleVisuals(btn, state[key])
        onFilterChange()
      })
    })
    document.getElementById('clear-filters')?.addEventListener('click', () => {
      state.regions.clear()
      state.difficulties.clear()
      state.monthDecades.clear()
      state.search = ''
      const search = document.getElementById('sports-search') as HTMLInputElement | null
      if (search) search.value = ''
      document.querySelectorAll('.filter-toggle').forEach(btn => {
        const key = (btn as HTMLElement).dataset.toggle as 'family' | 'elder'
        if (key && state[key]) {
          state[key] = false
          setToggleVisuals(btn, false)
        }
      })
      onFilterChange()
    })
    const search = document.getElementById('sports-search') as HTMLInputElement | null
    search?.addEventListener('input', (e) => {
      state.search = (e.target as HTMLInputElement).value
      renderTrails(applyFilters())
      renderClearButton()
    })
  }

  function updateSynced(d: Date) {
    const el = document.getElementById('last-synced')
    if (el) el.textContent = d.toLocaleString('zh-CN', { hour12: false })
  }

  let defaultsApplied = false
  function applyDefaultSelection() {
    if (defaultsApplied) return
    defaultsApplied = true
    const m = new Date().getMonth() + 1
    state.monthDecades.add(decadeKey(m, currentDecade()))
  }

  function hydrate(rows: Row[], syncedAt?: Date) {
    state.all = rows
    applyDefaultSelection()
    loadingEl?.classList.add('hidden')
    contentEl?.classList.remove('hidden')
    setTabVisuals()
    renderAll()
    if (syncedAt) updateSynced(syncedAt)
  }

  // 1. Render build-time data immediately (if any)
  let initial: Row[] = []
  try {
    initial = JSON.parse(container?.dataset.initialRows || '[]') as Row[]
  } catch {}
  const initialSynced = container?.dataset.initialSynced
  const hasInitial = initial.length > 0

  if (hasInitial) {
    hydrate(initial, initialSynced ? new Date(initialSynced) : undefined)
    bindEvents()
  }

  // 2. Try to refresh live from Google Sheet
  async function refresh() {
    try {
      const res = await fetch(sheetUrl, { cache: 'no-store' })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const text = await res.text()
      const rows = rowsToData(parseCSV(text))
      if (rows.length === 0) throw new Error('Empty data')

      const wasHydrated = hasInitial
      hydrate(rows, new Date())
      if (!wasHydrated) bindEvents()
    } catch (err) {
      console.warn('Live refresh failed, keeping build-time data:', err)
      if (!hasInitial) {
        loadingEl?.classList.add('hidden')
        errorEl?.classList.remove('hidden')
      }
    }
  }

  refresh()
</script>
